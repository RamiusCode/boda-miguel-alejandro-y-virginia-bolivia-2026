<!-- 🎵 BOTÓN FLOTANTE PLAY/PAUSE                                -->
<!-- ═══════════════════════════════════════════════════════════ -->
<button
    id="btn-audio-control"
    aria-label="Controlar música"
    class="fixed bottom-6 right-6 z-[9999] w-12 h-12 rounded-full shadow-lg
           bg-white border border-[#122a4d]/20 flex items-center justify-center
           transition-all duration-300 hover:scale-110 active:scale-95"
    style="opacity: 0; pointer-events: none;"
>
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#122a4d]"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <rect x="6" y="4" width="4" height="16" rx="1"></rect>
        <rect x="14" y="4" width="4" height="16" rx="1"></rect>
    </svg>
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-[#122a4d] hidden"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <path d="M8 5v14l11-7z"></path>
    </svg>
</button>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // ═══ ANIMACIÓN DEL SOBRE ═══
        gsap.fromTo(
            "#sobre-imagen",
            { opacity: 0, y: -100, scale: 0.8, rotation: -5 },
            {
                opacity: 1,
                y: 0,
                scale: 1,
                rotation: 0,
                duration: 1.2,
                ease: "back.out(1.3)",
                scrollTrigger: {
                    trigger: "#sobre-container",
                    start: "top 80%",
                    toggleActions: "play none none reset",
                },
            },
        );

        gsap.to("#sobre-imagen", {
            y: -10,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.2,
        });

        // ═══ ANIMACIÓN VERSÍCULO ═══
        gsap.fromTo(
            "#card-versiculo",
            { opacity: 0, y: 40, scale: 0.95 },
            {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 1,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#versiculo-container",
                    start: "top 80%",
                    toggleActions: "play none none reset",
                },
            },
        );

        // ═══ ANIMACIÓN TARJETA IZQUIERDA ═══
        gsap.fromTo(
            "#tarjeta-izquierda",
            { opacity: 0, x: -100 },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none reset",
                },
                delay: 0.3,
            },
        );

        // ═══ ANIMACIÓN TARJETA DERECHA ═══
        gsap.fromTo(
            "#tarjeta-derecha",
            { opacity: 0, x: 100 },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none reset",
                },
                delay: 0.5,
            },
        );

        // ═══ BOTÓN FLOTANTE PLAY/PAUSE ═══
        const btnAudio = document.getElementById(
            "btn-audio-control",
        ) as HTMLButtonElement;
        const iconoPlay = document.getElementById("icono-play");
        const iconoPause = document.getElementById("icono-pause");

        const intervalo = setInterval(() => {
            const audio = (window as any).audioGlobal;
            if (audio) {
                clearInterval(intervalo);
                gsap.to(btnAudio, {
                    opacity: 1,
                    duration: 0.5,
                    ease: "power2.out",
                    onStart: () => {
                        btnAudio.style.pointerEvents = "auto";
                    },
                });
                iconoPlay?.classList.add("hidden");
                iconoPause?.classList.remove("hidden");

                btnAudio.addEventListener("click", () => {
                    const audioActual = (window as any).audioGlobal;
                    const reproduciendo = (window as any)
                        .estaReproduciendoGlobal;
                    if (!audioActual) return;
                    if (reproduciendo) {
                        audioActual.pause();
                        (window as any).estaReproduciendoGlobal = false;
                        iconoPause?.classList.add("hidden");
                        iconoPlay?.classList.remove("hidden");
                    } else {
                        audioActual.play();
                        (window as any).estaReproduciendoGlobal = true;
                        iconoPlay?.classList.add("hidden");
                        iconoPause?.classList.remove("hidden");
                    }
                    gsap.fromTo(
                        btnAudio,
                        { scale: 0.85 },
                        { scale: 1, duration: 0.3, ease: "back.out(2)" },
                    );
                });
            }
        }, 300);
    });
</script>

